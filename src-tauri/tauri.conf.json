{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IPNetworkCalculator",
  "version": "0.1.0",
  "identifier": "com.local.ipnetworkcalculator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "IP 地址计算器",
        "width": 920,
        "height": 600,
        "minWidth": 900,
        "minHeight": 580,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "color": "#F3F8FA99"
        },
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost http://127.0.0.1:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
